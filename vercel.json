{
  "version": 2,
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1.js",
      "methods": ["GET", "POST", "PUT", "DELETE", "OPTIONS"]
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "functions": {
    "api/submit-application.js": { "memory": 512, "maxDuration": 30 },
    "api/initiate-payment.js": { "memory": 512, "maxDuration": 60 },
    "api/payment-callback.js": { "memory": 512, "maxDuration": 30 },
    "api/check-payment-status.js": { "memory": 512, "maxDuration": 30 },
    "api/tour-registration.js": { "memory": 512, "maxDuration": 30 },
    "api/chat.js": { "memory": 1024, "maxDuration": 60 }
  }
}
