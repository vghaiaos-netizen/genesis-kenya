# Genesis Kenya — Environment Variables Template
# Copy this file to .env.local and fill in actual values (never commit .env files)

# Google Sheets Authentication
GOOGLE_SHEET_ID=your-google-sheet-id-here
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account-email@project-id.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n[paste your private key here with \n for newlines]\n-----END PRIVATE KEY-----\n"

# Tuma M-Pesa API
TUMA_EMAIL=your-tuma-business@example.com
TUMA_API_KEY=your-tuma-api-key-here

# Groq AI API Keys (3 keys for rate limiting rotation)
GROQ_API_KEY_1=your-groq-key-1
GROQ_API_KEY_2=your-groq-key-2
GROQ_API_KEY_3=your-groq-key-3

# Vercel (auto-filled, don't edit)
VERCEL_URL=https://genesis-kenya.vercel.app
